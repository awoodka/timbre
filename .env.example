GEMINI_API_KEY=your-gemini-api-key-here
TMDB_API_KEY=your-tmdb-api-key-here
RAWG_API_KEY=your-rawg-api-key-here

# Local Postgres (matches docker-compose `db` service). For a hosted DB
# (RDS / Supabase / Neon), swap this URL and set DB_SSL=true.
DATABASE_URL=postgresql+asyncpg://mediafingerprint:mediafingerprint@localhost:5432/mediafingerprint
DB_SSL=false

# Auth: secret used to sign JWT session cookies. Optional locally (a dev default
# is used), but REQUIRED in production — set to a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# HTTPS-only session cookies. Keep false for local http dev.
COOKIE_SECURE=false

# ---- Production (fill in when hosting; activated by docker-compose.prod.yml) ----
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# COOKIE_SECURE=true          # cookies become HTTPS-only (correct behind the tunnel)
# DB_SSL=true                 # only if using a hosted Postgres that requires TLS
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DBNAME   # hosted DB (else the bundled db service)
